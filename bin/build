#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

DERIVED_DATA="$ROOT/build"
APP="$DERIVED_DATA/Build/Products/Release/CSVDrop.app"
DIST="$ROOT/dist"
VERSION="$(
  sed -n 's/.*MARKETING_VERSION = \(.*\);/\1/p' CSVDrop.xcodeproj/project.pbxproj | head -1 | tr -d ' '
)"
ZIP="$DIST/CSVDrop-${VERSION}.zip"

mkdir -p "$DIST"

rm -rf "$DERIVED_DATA"

echo "Building CSV Drop ${VERSION}..."
xcodebuild \
  -project CSVDrop.xcodeproj \
  -scheme CSVDrop \
  -configuration Release \
  -derivedDataPath "$DERIVED_DATA" \
  build

rm -f "$ZIP"
COPYFILE_DISABLE=1 ditto -c -k --keepParent "$APP" "$ZIP"

echo "Wrote $ZIP"
