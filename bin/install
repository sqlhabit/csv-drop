#!/usr/bin/env bash
set -euo pipefail

GITHUB_REPO="sqlhabit/csv-drop"
APP_PATH="/Applications/CSVDrop.app"

info() { printf '==> %s\n' "$*"; }
warn() { printf 'warning: %s\n' "$*" >&2; }
die() { printf 'error: %s\n' "$*" >&2; exit 1; }

require_macos() {
  [[ "$(uname -s)" == "Darwin" ]] || die "This installer supports macOS only."
}

check_gcloud() {
  if command -v bq >/dev/null 2>&1 && command -v gcloud >/dev/null 2>&1; then
    info "Google Cloud SDK found ($(command -v bq))"
    return
  fi

  warn "bq and gcloud were not found on your PATH."
  if command -v brew >/dev/null 2>&1; then
    info "Install the Google Cloud SDK with:"
    printf '  brew install --cask google-cloud-sdk\n'
  else
    info "Install the Google Cloud SDK from:"
    printf '  https://cloud.google.com/sdk/docs/install\n'
  fi
  printf '\nAfter installing, authenticate:\n'
  printf '  gcloud auth login\n'
  printf '  gcloud auth application-default login   # optional, if bq asks for ADC\n'
  exit 1
}

install_bqcsv() {
  if command -v bqcsv >/dev/null 2>&1; then
    info "bqcsv is already installed ($(command -v bqcsv))"
    return
  fi

  if command -v brew >/dev/null 2>&1; then
    info "Installing bqcsv with Homebrew Python..."
    if ! brew list python &>/dev/null; then
      brew install python
    fi
    "$(brew --prefix)/bin/pip3" install --upgrade bqcsv
    command -v bqcsv >/dev/null 2>&1 || die "bqcsv install finished but the command is not on PATH."
    info "bqcsv installed ($(command -v bqcsv))"
    return
  fi

  if command -v pipx >/dev/null 2>&1; then
    info "Installing bqcsv with pipx..."
    pipx install bqcsv
    info "bqcsv installed ($(command -v bqcsv))"
    warn "CSV Drop looks for bqcsv in /opt/homebrew/bin and /usr/local/bin."
    warn "If uploads fail, set BQCSV_PATH to $(command -v bqcsv)."
    return
  fi

  info "Installing bqcsv with pip (user install)..."
  python3 -m pip install --user --upgrade bqcsv
  warn "CSV Drop may not see user-installed CLIs. Set BQCSV_PATH if uploads fail:"
  warn "  export BQCSV_PATH=\"\$(python3 -m site --user-base)/bin/bqcsv\""
}

resolve_latest_release_url() {
  local api_json url

  if api_json="$(
    curl -fsSL \
      -H "Accept: application/vnd.github+json" \
      -H "User-Agent: CSVDrop-install-script" \
      "https://api.github.com/repos/${GITHUB_REPO}/releases/latest" 2>/dev/null
  )"; then
    url="$(
      printf '%s' "$api_json" | python3 -c "
import json, sys
data = json.load(sys.stdin)
assets = data.get('assets', [])
for asset in assets:
    if asset['name'].startswith('CSVDrop') and asset['name'].endswith('.zip'):
        print(asset['browser_download_url'])
        break
else:
    for asset in assets:
        if asset['name'].endswith('.zip'):
            print(asset['browser_download_url'])
            break
    else:
        sys.exit(1)
" 2>/dev/null
    )" || true
    if [[ -n "$url" ]]; then
      printf '%s\n' "$url"
      return 0
    fi
  fi

  if command -v gh >/dev/null 2>&1; then
    url="$(gh release view --repo "$GITHUB_REPO" --json assets -q '.assets[] | select(.name | test("^CSVDrop-.*\\.zip$")) | .url' 2>/dev/null | head -1)" || true
    if [[ -n "$url" ]]; then
      printf '%s\n' "$url"
      return 0
    fi
  fi

  url="$(
    curl -fsSL "https://github.com/${GITHUB_REPO}/releases/latest" 2>/dev/null |
      grep -oE "https://github.com/${GITHUB_REPO}/releases/download/[^/]+/CSVDrop-[^\"]+\.zip" |
      head -1
  )" || true
  if [[ -n "$url" ]]; then
    printf '%s\n' "$url"
    return 0
  fi

  return 1
}

install_csvdrop() {
  local url tmpdir

  if [[ -d "$APP_PATH" ]]; then
    info "Updating existing CSV Drop installation..."
  else
    info "Installing CSV Drop from the latest GitHub release..."
  fi

  url="$(resolve_latest_release_url)" || die "Could not find a release archive at https://github.com/${GITHUB_REPO}/releases"

  tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/csvdrop-install.XXXXXX")"
  curl -fsSL -o "${tmpdir}/CSVDrop.zip" "$url"
  unzip -q -o "${tmpdir}/CSVDrop.zip" -d "$tmpdir"
  [[ -d "${tmpdir}/CSVDrop.app" ]] || die "Release archive did not contain CSVDrop.app"

  rm -rf "$APP_PATH"
  mv "${tmpdir}/CSVDrop.app" "$APP_PATH"
  rm -rf "$tmpdir"

  info "Installed CSV Drop to ${APP_PATH}"
}

print_completion_message() {
  printf '\n'
  info "Setup complete."
  info "Open CSV Drop from Applications or run:"
  printf '  open %s\n' "$APP_PATH"
  warn "On first launch, macOS may block the app because it is not from the App Store."
  warn "Open System Settings → Privacy & Security and choose Open Anyway if prompted."
}

usage() {
  cat <<'EOF'
Usage: install [OPTIONS]

Install CSV Drop and its CLI dependencies on macOS.

Options:
  --skip-app   Skip downloading CSVDrop.app (e.g. you installed from the Mac App Store)
  -h, --help   Show this help
EOF
}

main() {
  local skip_app=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skip-app) skip_app=1 ;;
      -h|--help) usage; exit 0 ;;
      *) die "Unknown option: $1 (try --help)" ;;
    esac
    shift
  done

  require_macos
  info "CSV Drop setup"
  if [[ "$skip_app" -eq 1 ]]; then
    info "Skipping CSV Drop app install (--skip-app)"
  else
    install_csvdrop
  fi
  install_bqcsv
  check_gcloud
  print_completion_message
}

main "$@"
